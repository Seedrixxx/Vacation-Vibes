// Vacation Vibes CMS - Prisma Schema
// Run: npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tour {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  durationDays    Int
  durationNights  Int
  price           Decimal  @db.Decimal(12, 2)
  rating          Float?
  highlights      String[] @default([])
  coverImage      String?
  gallery         String[] @default([])
  featured        Boolean  @default(false)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
}

model Destination {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  country      String?
  focusInbound Boolean       @default(false)
  heroImage    String?
  description  String?
  summary      String?
  activities        String[]             @default([])
  createdAt         DateTime             @default(now())
  experiences       Experience[]
  packagesPrimary   Package[]            @relation("PrimaryDestination")
  packageRouteStops PackageRouteStop[]
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  country   String
  rating    Int
  review    String
  image     String?
  createdAt DateTime @default(now())
}

model BlogPost {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  excerpt      String?
  content      String?
  heroImageUrl String?
  authorName   String?
  publishedAt  DateTime?
  isPublished  Boolean   @default(false)
  createdAt    DateTime  @default(now())
}

model Experience {
  id                    String                @id @default(cuid())
  name                  String
  slug                  String                @unique
  destinationId         String?
  destination           Destination?          @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  tags                  String[]              @default([])
  priceFrom             Int?
  imageUrl              String?
  description           String?
  createdAt             DateTime              @default(now())
  packageDayExperiences PackageDayExperience[]
}

model Inquiry {
  id                 String   @id @default(cuid())
  name               String
  email              String
  phone              String?
  message            String?
  sourcePage         String?
  tripDesignerPayload Json?
  createdAt          DateTime @default(now())
}

model Deposit {
  id                    String   @id @default(cuid())
  inquiryId             String?
  packageId             String?
  amount                Int
  currency              String
  status                String
  stripeSessionId       String?
  stripePaymentIntentId String?
  customerEmail         String?
  createdAt             DateTime @default(now())
}

enum TripRequestStatus {
  PENDING
  CONTACTED
  CONFIRMED
  CANCELLED
}

model TripRequest {
  id        String            @id @default(cuid())
  fullName  String
  email     String
  whatsapp  String?
  startDate DateTime?
  endDate   DateTime?
  budget    String?
  interests String[]          @default([])
  message   String?
  status    TripRequestStatus  @default(PENDING)
  createdAt DateTime          @default(now())
}

model PackageCustomizationRequest {
  id                  String   @id @default(cuid())
  packageId           String
  packageSlug         String
  packageName         String
  matchScore          Int?
  builderInputsJson   Json
  requestedChangesJson Json?
  customerFullName    String
  customerEmail       String
  customerWhatsapp    String?
  message             String?
  status              String   @default("PENDING")
  source              String   @default("BUILD_TRIP")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ---- Trip Commerce ----

enum TripType {
  INBOUND
  OUTBOUND
}

enum PackageCtaMode {
  PAY_NOW
  GET_QUOTE
  BOOK_NOW
  PAY_DEPOSIT
  CONTACT_AGENT
}

enum PackageListItemType {
  HIGHLIGHT
  INCLUSION
  EXCLUSION
  NOTE
}

enum DepositType {
  NONE
  FIXED
  PERCENT
}

enum TripBuilderOptionType {
  TRIP_TYPE
  COUNTRY
  CITY
  DURATION
  HOTEL_CLASS
  TRANSPORT
  MEAL_PLAN
  ACTIVITY
  ADD_ON
}

enum PriceType {
  NONE
  FIXED
  PER_PAX
  PER_DAY
  PER_NIGHT
}

enum TripOrderSource {
  PACKAGE
  BUILD_TRIP
}

enum PaymentStatus {
  UNPAID
  PAID
}

enum TripStatus {
  PENDING
  PAID
  PROCESSING
  APPROVED
}

enum HandoffMode {
  CHECKOUT
  AGENT
}

enum PaymentProvider {
  STRIPE
}

model Package {
  id                    String                 @id @default(cuid())
  title                 String
  slug                  String                 @unique
  tripType              TripType
  country               String?
  primaryDestinationId  String?
  primaryDestination    Destination?           @relation("PrimaryDestination", fields: [primaryDestinationId], references: [id], onDelete: SetNull)
  durationNights        Int
  durationDays          Int
  summary               String
  shortDescription      String?
  overview              String?
  content               String?
  heroImage             String?
  gallery               String[]               @default([])
  tags                  String[]               @default([])
  featured              Boolean                @default(false)
  startingPrice         Int?
  startingPriceCurrency String?                @default("USD")
  badge                 String?
  templateEligible      Boolean                @default(false)
  ctaMode               PackageCtaMode
  isPublished           Boolean                @default(false)
  metaTitle             String?
  metaDescription       String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  packageDays             PackageDay[]
  packageListItems        PackageListItem[]
  packagePricingOptions   PackagePricingOption[]
  packageRouteStops       PackageRouteStop[]
  packageHotelOptions     PackageHotelOption[]
  tripOrders              TripOrder[]
  @@index([isPublished])
  @@index([isPublished, updatedAt])
  @@index([primaryDestinationId])
}

model PackageRouteStop {
  id             String     @id @default(cuid())
  packageId      String
  package        Package    @relation(fields: [packageId], references: [id], onDelete: Cascade)
  destinationId  String?
  destination    Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  freeTextLocation String?
  orderIndex     Int        @default(0)
  @@index([packageId])
}

model PackageHotelOption {
  id         String   @id @default(cuid())
  packageId  String
  package    Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  tierName   String?
  hotelName  String?
  location   String?
  category   String?
  mealPlan   String?
  roomType   String?
  dayFrom    Int?
  dayTo      Int?
  orderIndex Int      @default(0)
  @@index([packageId])
}

model PackageDay {
  id              String                  @id @default(cuid())
  packageId       String
  package         Package                @relation(fields: [packageId], references: [id], onDelete: Cascade)
  dayNumber       Int
  fromLocation    String?
  toLocation      String?
  overnightLocation String?
  title           String?
  summary         String?
  description     String
  meals           String?
  notes           String?
  modules         String[]               @default([])
  isOptional      Boolean                @default(false)
  dayImage        String?
  order           Int                    @default(0)
  dayExperiences  PackageDayExperience[]
  @@index([packageId, order])
}

model PackageDayExperience {
  id           String    @id @default(cuid())
  packageDayId String
  packageDay   PackageDay @relation(fields: [packageDayId], references: [id], onDelete: Cascade)
  experienceId String?
  experience   Experience? @relation(fields: [experienceId], references: [id], onDelete: SetNull)
  customLabel  String?
  orderIndex   Int       @default(0)
  @@index([packageDayId])
}

model PackageListItem {
  id        String             @id @default(cuid())
  packageId String
  package   Package            @relation(fields: [packageId], references: [id], onDelete: Cascade)
  type      PackageListItemType
  label     String
  order     Int                @default(0)
  @@index([packageId, type, order])
}

model PackagePricingOption {
  id            String      @id @default(cuid())
  packageId     String
  package       Package     @relation(fields: [packageId], references: [id], onDelete: Cascade)
  label         String
  pricingBasis  String?
  occupancyType String?
  currency      String      @default("USD")
  basePrice     Int
  salePrice     Int?
  depositType   DepositType @default(NONE)
  depositValue  Int?
  quoteOnly     Boolean     @default(false)
  tierName      String?
  orderIndex    Int         @default(0)
  isActive      Boolean     @default(true)
  notes         String?
  @@index([packageId])
  tripOrders    TripOrder[]
}

model TripBuilderOption {
  id           String               @id @default(cuid())
  optionType   TripBuilderOptionType
  label        String
  description  String?
  valueKey     String               @unique
  enabled      Boolean              @default(true)
  order        Int                  @default(0)
  priceType    PriceType            @default(NONE)
  priceAmount  Int?
  currency     String               @default("USD")
  metadataJson Json?
  @@index([optionType, order])
}

model ItineraryTemplate {
  id             String   @id @default(cuid())
  tripType       String?
  country        String?
  durationNights Int
  durationDays   Int
  tags           String[] @default([])
  templateJson   Json
  enabled        Boolean  @default(true)
  @@index([tripType, country, durationNights])
}

model TripOrder {
  id                String          @id @default(cuid())
  invoiceNumber     String          @unique
  trackingToken     String?         @unique
  source            TripOrderSource
  packageId         String?
  package           Package?        @relation(fields: [packageId], references: [id], onDelete: SetNull)
  pricingOptionId   String?
  pricingOption     PackagePricingOption? @relation(fields: [pricingOptionId], references: [id], onDelete: SetNull)
  customerFullName  String
  customerEmail     String
  customerWhatsapp  String?
  tripType          String?
  country           String?
  startDate         DateTime?
  endDate           DateTime?
  paxAdults         Int?
  paxChildren       Int?
  inputsJson        Json
  itineraryJson     Json
  pricingJson       Json
  currency          String          @default("USD")
  totalAmount       Int?
  depositAmount     Int?
  paymentStatus     PaymentStatus  @default(UNPAID)
  tripStatus        TripStatus     @default(PENDING)
  handoffMode       HandoffMode
  assignedTo        String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  paymentReceipts   PaymentReceipt[]
  @@index([createdAt])
}

model PaymentReceipt {
  id                    String           @id @default(cuid())
  tripOrderId           String
  tripOrder             TripOrder        @relation(fields: [tripOrderId], references: [id], onDelete: Cascade)
  provider              PaymentProvider
  stripeSessionId       String
  stripePaymentIntentId String?
  amountPaid            Int
  currency              String
  receiptUrl            String?
  rawJson               Json?
  createdAt             DateTime         @default(now())
  @@index([tripOrderId])
  @@index([createdAt])
}

model InvoiceSequence {
  id         String @id @default(cuid())
  yearMonth  String @unique
  lastNumber Int    @default(0)
}

enum TripProposalSourcePath {
  MATCHED_PACKAGE_CUSTOMIZATION
  FULL_CUSTOM_BUILD
}

enum ProposalPricingStatus {
  CALCULATED
  ESTIMATED
  REVIEW_REQUIRED
}

model TripProposal {
  id              String                 @id @default(cuid())
  sourcePath      TripProposalSourcePath
  packageRefJson  Json?
  country         String
  tripType        String
  durationDays    Int
  durationNights  Int
  paxAdults       Int
  paxChildren     Int
  paxSeniors      Int?
  interestsJson   Json                   @default("[]")
  travelStyle     String?
  budgetTier       String?
  summary         String                 @db.Text
  itineraryDaysJson Json                @default("[]")
  pricingStatus   ProposalPricingStatus
  pricingJson     Json?
  customerFullName String
  customerEmail   String
  customerWhatsapp String?
  leadStatus      String?                @default("NEW")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}
