// Vacation Vibes CMS - Prisma Schema
// Run: npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tour {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  durationDays    Int
  durationNights  Int
  price           Decimal  @db.Decimal(12, 2)
  rating          Float?
  highlights      String[] @default([])
  coverImage      String?
  gallery         String[] @default([])
  featured        Boolean  @default(false)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
}

model Destination {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  heroImage   String?
  description String?
  activities  String[] @default([])
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  country   String
  rating    Int
  review    String
  image     String?
  createdAt DateTime @default(now())
}

enum TripRequestStatus {
  PENDING
  CONTACTED
  CONFIRMED
  CANCELLED
}

model TripRequest {
  id        String            @id @default(cuid())
  fullName  String
  email     String
  whatsapp  String?
  startDate DateTime?
  endDate   DateTime?
  budget    String?
  interests String[]          @default([])
  message   String?
  status    TripRequestStatus  @default(PENDING)
  createdAt DateTime          @default(now())
}

// ---- Trip Commerce ----

enum TripType {
  INBOUND
  OUTBOUND
}

enum PackageCtaMode {
  PAY_NOW
  GET_QUOTE
}

enum PackageListItemType {
  HIGHLIGHT
  INCLUSION
  EXCLUSION
}

enum DepositType {
  NONE
  FIXED
  PERCENT
}

enum TripBuilderOptionType {
  TRIP_TYPE
  COUNTRY
  CITY
  DURATION
  HOTEL_CLASS
  TRANSPORT
  MEAL_PLAN
  ACTIVITY
  ADD_ON
}

enum PriceType {
  NONE
  FIXED
  PER_PAX
  PER_DAY
  PER_NIGHT
}

enum TripOrderSource {
  PACKAGE
  BUILD_TRIP
}

enum PaymentStatus {
  UNPAID
  PAID
}

enum TripStatus {
  PENDING
  PAID
  PROCESSING
  APPROVED
}

enum HandoffMode {
  CHECKOUT
  AGENT
}

enum PaymentProvider {
  STRIPE
}

model Package {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  tripType        TripType
  durationNights Int
  durationDays    Int
  summary         String
  content         String?
  heroImage       String?
  gallery         String[]        @default([])
  tags            String[]        @default([])
  ctaMode         PackageCtaMode
  isPublished     Boolean         @default(false)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  packageDays             PackageDay[]
  packageListItems        PackageListItem[]
  packagePricingOptions    PackagePricingOption[]
  tripOrders               TripOrder[]
}

model PackageDay {
  id           String   @id @default(cuid())
  packageId    String
  package     Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  dayNumber    Int
  fromLocation String?
  toLocation   String?
  title        String?
  description  String
  modules      String[] @default([])
  isOptional   Boolean  @default(false)
  dayImage     String?
  order        Int      @default(0)
  @@index([packageId, order])
}

model PackageListItem {
  id        String             @id @default(cuid())
  packageId String
  package   Package            @relation(fields: [packageId], references: [id], onDelete: Cascade)
  type      PackageListItemType
  label     String
  order     Int                @default(0)
  @@index([packageId, type, order])
}

model PackagePricingOption {
  id           String      @id @default(cuid())
  packageId    String
  package      Package     @relation(fields: [packageId], references: [id], onDelete: Cascade)
  label        String
  currency     String      @default("USD")
  basePrice    Int
  salePrice    Int?
  depositType  DepositType @default(NONE)
  depositValue Int?
  isActive     Boolean     @default(true)
  notes        String?
  @@index([packageId])
  tripOrders   TripOrder[]
}

model TripBuilderOption {
  id           String               @id @default(cuid())
  optionType   TripBuilderOptionType
  label        String
  description  String?
  valueKey     String               @unique
  enabled      Boolean              @default(true)
  order        Int                  @default(0)
  priceType    PriceType            @default(NONE)
  priceAmount  Int?
  currency     String               @default("USD")
  metadataJson Json?
  @@index([optionType, order])
}

model ItineraryTemplate {
  id             String   @id @default(cuid())
  tripType       String?
  country        String?
  durationNights Int
  durationDays   Int
  tags           String[] @default([])
  templateJson   Json
  enabled        Boolean  @default(true)
  @@index([tripType, country, durationNights])
}

model TripOrder {
  id                String          @id @default(cuid())
  invoiceNumber     String          @unique
  source            TripOrderSource
  packageId         String?
  package           Package?        @relation(fields: [packageId], references: [id], onDelete: SetNull)
  pricingOptionId   String?
  pricingOption     PackagePricingOption? @relation(fields: [pricingOptionId], references: [id], onDelete: SetNull)
  customerFullName  String
  customerEmail     String
  customerWhatsapp  String?
  tripType          String?
  country           String?
  startDate         DateTime?
  endDate           DateTime?
  paxAdults         Int?
  paxChildren       Int?
  inputsJson        Json
  itineraryJson     Json
  pricingJson       Json
  currency          String          @default("USD")
  totalAmount       Int?
  depositAmount     Int?
  paymentStatus     PaymentStatus  @default(UNPAID)
  tripStatus        TripStatus     @default(PENDING)
  handoffMode       HandoffMode
  assignedTo        String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  paymentReceipts   PaymentReceipt[]
}

model PaymentReceipt {
  id                    String           @id @default(cuid())
  tripOrderId           String
  tripOrder             TripOrder        @relation(fields: [tripOrderId], references: [id], onDelete: Cascade)
  provider              PaymentProvider
  stripeSessionId       String
  stripePaymentIntentId String?
  amountPaid            Int
  currency              String
  receiptUrl            String?
  rawJson               Json?
  createdAt             DateTime         @default(now())
}

model InvoiceSequence {
  id         String @id @default(cuid())
  yearMonth  String @unique
  lastNumber Int    @default(0)
}
